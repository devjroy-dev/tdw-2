{
  "expo": {
    "name": "The Dream Wedding",
    "slug": "the-dream-wedding",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dreamwedding",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.thedreamwedding.app"
    },
    "android": {
      "package": "in.thedreamwedding.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-contacts",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#F5F0E8",
          "dark": {
            "backgroundColor": "#F5F0E8"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "883af0e2-8826-4a99-aedb-f85eb1d2d912"
      }
    },
    "owner": "devjroy",
    "splash": {
      "backgroundColor": "#F5F0E8",
      "resizeMode": "contain",
      "image": "./assets/images/splash-icon.png"
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/883af0e2-8826-4a99-aedb-f85eb1d2d912",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "channel": "production"
    }
  }
}