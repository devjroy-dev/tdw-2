{
  "expo": {
    "name": "The Dream Wedding",
    "slug": "DreamWedding",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dreamwedding",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devjroy.dreamwedding"
    },
    "android": {
      "package": "com.devjroy.dreamwedding",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/cormorant-garamond/CormorantGaramond_300Light.ttf",
            "./node_modules/@expo-google-fonts/cormorant-garamond/CormorantGaramond_400Regular.ttf",
            "./node_modules/@expo-google-fonts/cormorant-garamond/CormorantGaramond_500Medium.ttf",
            "./node_modules/@expo-google-fonts/cormorant-garamond/CormorantGaramond_600SemiBold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#F5F0E8",
          "dark": {
            "backgroundColor": "#F5F0E8"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f6d681f-42ce-4436-9230-4b126626ef10"
      }
    },
    "owner": "devjroy"
  }
}