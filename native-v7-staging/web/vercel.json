{
  "rewrites": [
    {
      "source": "/",
      "destination": "/"
    },
    {
      "source": "/admin",
      "destination": "/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin"
    },
    {
      "source": "/vendor/login",
      "destination": "/vendor/login"
    },
    {
      "source": "/vendor/dashboard",
      "destination": "/vendor/dashboard"
    },
    {
      "source": "/vendor/demo",
      "destination": "/vendor/demo"
    },
    {
      "source": "/couple",
      "destination": "/couple"
    },
    {
      "source": "/couple/login",
      "destination": "/couple/login"
    },
    {
      "source": "/about",
      "destination": "/about"
    },
    {
      "source": "/join/:code",
      "destination": "/join/[code]"
    }
  ]
}